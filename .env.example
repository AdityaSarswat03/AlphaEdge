# ────────────────────────────────────────────────────────────────
# AlphaEdge — Environment Variables
# ────────────────────────────────────────────────────────────────

# Application
APP_ENV=development
DEBUG=true
SECRET_KEY=dev-secret-key-change-in-production

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# ── Firebase (Database & Backend) ────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS_PATH=config/firebase-service-account.json
FIREBASE_CREDENTIALS_JSON=
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_DATABASE_URL=

# ── Clerk (Authentication) ──────────────────────────────────────
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxx
CLERK_DOMAIN=your-app.clerk.accounts.dev
ENABLE_CLERK_AUTH=false

# ── Cloudflare (DNS & CDN) ──────────────────────────────────────
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ZONE_ID=your-zone-id
CLOUDFLARE_ACCOUNT_ID=your-account-id
DOMAIN_NAME=alphaedge.ai
API_SUBDOMAIN=api
DASHBOARD_SUBDOMAIN=app

# ── GitHub ──────────────────────────────────────────────────────
GITHUB_REPO=adityas/AlphaEdge
GITHUB_TOKEN=

# Redis (optional - uses in-memory fallback in dev)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
ENABLE_REDIS_CACHE=false

# Model Configuration
MAX_SEQUENCE_LENGTH=60
PREDICTION_HORIZON=5

# Training
TRAIN_BATCH_SIZE=64
EPOCHS=100
LEARNING_RATE=0.001

# Backtesting
INITIAL_CAPITAL=100000.0
COMMISSION_RATE=0.001

# Logging
LOG_LEVEL=INFO

# Feature Flags
ENABLE_SENTIMENT_ANALYSIS=true
ENABLE_TECHNICAL_ANALYSIS=true
ENABLE_ENSEMBLE_MODEL=true
ENABLE_BACKTESTING=true
ENABLE_REAL_TIME_DATA=false

# API Keys (optional)
YAHOO_FINANCE_API_KEY=
ALPHA_VANTAGE_API_KEY=
NEWS_API_KEY=
